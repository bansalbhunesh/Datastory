# --- OpenMetadata ---
OM_BASE_URL=http://localhost:8585
# Provide EITHER a token, OR email+password. Token wins if both are set.
OM_TOKEN=
OM_EMAIL=admin@open-metadata.org
OM_PASSWORD=admin

# --- LLM (Anthropic) ---
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Server ---
BACKEND_PORT=8080
LOG_LEVEL=info
REQUEST_TIMEOUT=45s
CACHE_TTL=60s
MAX_BODY_BYTES=1048576
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
