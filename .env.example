# Copy to repo root `.env` for `make dev` (backend loads ../.env and ./.env).

# OpenMetadata (from `make mock` quickstart: http://localhost:8585)
OM_BASE_URL=http://localhost:8585
# Prefer a JWT from the UI (Settings) or login below
OM_TOKEN=
OM_EMAIL=admin@open-metadata.org
OM_PASSWORD=admin

# Anthropic
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Backend
BACKEND_PORT=8080
