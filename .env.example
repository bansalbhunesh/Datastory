# Copy to repo root `.env` for `make dev` (backend loads ../.env and ./.env).

# --- OpenMetadata (required) ---
# From `make mock` quickstart: http://localhost:8585
OM_BASE_URL=http://localhost:8585
# Provide a JWT (preferred) OR email+password. Token wins if both are set.
OM_TOKEN=
OM_EMAIL=admin@open-metadata.org
OM_PASSWORD=admin

# --- Anthropic (optional; deterministic fallback used when empty) ---
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Backend tuning (optional) ---
BACKEND_PORT=8080
LOG_LEVEL=info
REQUEST_TIMEOUT=45s
CACHE_TTL=60s
MAX_BODY_BYTES=1048576

# Shared secret enforced by the API. When set, ALLOWED_ORIGINS must NOT be '*'.
# The frontend must send the same value via VITE_API_KEY -> X-API-Key.
API_KEY=

RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=20
INCIDENT_LOG_PATH=data/incidents.db
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Frontend (Vite, only read by `npm run dev` / `npm run build`) ---
# Mirror API_KEY here when API_KEY is set on the server.
VITE_API_KEY=
